# Copy this file to .env and fill in real values.
# Never commit .env or real credentials to version control.

# Supabase
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App
PORT=3000
VITE_APP_URL=https://your-site.vercel.app
VITE_SERVER_URL=http://localhost:3000
VITE_EMAIL_NOTIFICATIONS_ENABLED=true
APP_DOMAIN=your-site.vercel.app
ADMIN_EMAIL=admin@example.com
SUPPORT_EMAIL=support@example.com
CONTACT_NOTIFICATION_EMAIL=support@example.com

# Email delivery via TurboSMTP
EMAIL_PROVIDER=turbosmtp
EMAIL_FROM=no-reply@example.com
EMAIL_FROM_NAME=eToro Trust Capital
EMAIL_REPLY_TO=noreply@example.com
EMAIL_REPLY_TO_NAME=eToro Trust Capital

# TurboSMTP SMTP settings
# Official docs list pro.eu.turbo-smtp.com with 587/2525/25 for non-SSL and 465/25025 for SSL.
SMTP_HOST=pro.eu.turbo-smtp.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_turbosmtp_consumer_key
SMTP_PASS=your_turbosmtp_consumer_secret
SMTP_FROM=no-reply@example.com
SMTP_FROM_NAME=eToro Trust Capital

# Optional frontend-only email endpoint override
VITE_EMAIL_API_ENDPOINT=/api/send-email

# Optional hosted logo override for email clients
EMAIL_LOGO_URL=https://your-site.vercel.app/images/email-logo.png
VITE_EMAIL_LOGO_URL=https://your-site.vercel.app/images/email-logo.png

# Optional reCAPTCHA
RECAPTCHA_SECRET=
