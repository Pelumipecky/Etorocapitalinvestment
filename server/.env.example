# Copy to .env and replace with your real values (DO NOT COMMIT .env with service_role key)
PORT=3000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service_role_xxx_replace_with_real_key
# Optional: a destination email address for contact notifications
CONTACT_NOTIFICATION_EMAIL=support@example.com

# Email Site & Logo URLs (explicitly configure for email notifications)
EMAIL_SITE_URL=https://your-site.vercel.app
EMAIL_LOGO_URL=https://your-site.vercel.app/images/email-logo.png

# Email delivery via TurboSMTP
EMAIL_FROM=noreply@etorocapital.online
EMAIL_FROM_NAME=eToro Trust Capital
EMAIL_REPLY_TO=noreply@etorocapital.online
EMAIL_REPLY_TO_NAME=eToro Trust Capital

EMAIL_PROVIDER=turbosmtp
# Official docs list pro.eu.turbo-smtp.com with 587/2525/25 for non-SSL and 465/25025 for SSL.
SMTP_HOST=pro.eu.turbo-smtp.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_turbosmtp_consumer_key
SMTP_PASS=your_turbosmtp_consumer_secret
SMTP_FROM=noreply@etorocapital.online
